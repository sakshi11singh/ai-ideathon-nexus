# Google Sheets API Configuration
# Follow GOOGLE_SHEET_API_SETUP.md for complete instructions

# Your Google Sheet ID (from the URL: docs.google.com/spreadsheets/d/THIS_PART/edit)
VITE_GOOGLE_SHEET_ID=your_sheet_id_here

# Google Cloud API Key
VITE_GOOGLE_API_KEY=your_api_key_here

# Optional: Email Service Configuration (for confirmations)
# Use EmailJS or Formspree for email notifications
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
